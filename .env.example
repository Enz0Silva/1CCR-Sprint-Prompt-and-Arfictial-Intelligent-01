# ================================
# ChargeGrid AI — Variáveis de Ambiente
# ================================
# Você deve preencher o seu .env com seus dados reais
# cp .env.example .env

# Groq API (gratuita) — obtenha sua chave em https://console.groq.com/keys
GROQ_API_KEY=sua-chave-aqui
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama3-70b-8192

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/chargegrid

# Backend
API_PORT=8000